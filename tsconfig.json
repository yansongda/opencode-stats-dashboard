{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["bun-types"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "emitDeclarationOnly": false,

    "baseUrl": ".",
    "paths": {
      "@defs/*": ["packages/shared/src/types/*"],
      "@opencode-stats/shared": ["packages/shared/src"],
      "@opencode-stats/shared/*": ["packages/shared/src/*"],
      "@opencode-stats/engine": ["packages/engine/src"],
      "@opencode-stats/engine/*": ["packages/engine/src/*"],
      "@opencode-stats/plugin": ["packages/plugin/src"],
      "@opencode-stats/plugin/*": ["packages/plugin/src/*"],
      "@opencode-stats/dashboard": ["packages/dashboard/src"],
      "@opencode-stats/dashboard/*": ["packages/dashboard/src/*"]
    }
  },
  "include": ["packages/*/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "packages/dashboard", "tests", "packages/*/tests", "packages/*/dist"],
}
