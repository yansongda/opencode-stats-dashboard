{
  "name": "@opencode-stats/plugin",
  "version": "1.0.0-beta.0",
  "description": "OpenCode Stats Engine Plugin",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --target=bun --format=esm --outdir=dist --external @opencode-ai/plugin --external @opencode-ai/sdk --external hono && tsc -p tsconfig.build.json && mv dist/packages/plugin/src/*.d.ts dist/ && rm -rf dist/packages",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "stats",
    "bun"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.16.0",
    "@opencode-ai/sdk": "^1.16.0",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "latest",
    "typescript": "^5.8.0"
  }
}
